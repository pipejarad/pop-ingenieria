# Variables de entorno — copia este archivo a .env.local y rellena los valores.
# (.env.local está ignorado por git; no subas tus claves al repositorio.)

# Resend — necesario para que el formulario de contacto envíe correos.
# Crea una API key en https://resend.com (dashboard → API Keys).
RESEND_API_KEY=

# Correo donde llegan las consultas del formulario.
# Opcional: por defecto usa el email de src/content/site.js.
CONTACT_TO_EMAIL=

# Remitente de los correos. Debe ser un dominio verificado en Resend,
# por ejemplo: "POP Ingeniería <contacto@pop-ingenieria.cl>".
# Opcional: por defecto usa el remitente sandbox de Resend (onboarding@resend.dev),
# que solo permite enviar a tu propio correo de la cuenta de Resend.
CONTACT_FROM_EMAIL=
